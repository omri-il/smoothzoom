<Window x:Class="SmoothZoom.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmoothZoom Settings"
        Width="400" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="SmoothZoom Settings" FontSize="18" FontWeight="SemiBold"
                   Foreground="#89B4FA" Margin="0,0,0,20"/>

        <TextBlock>
            <Run Text="Zoom Level: "/>
            <Run x:Name="ZoomLevelLabel" Text="2.0x" FontWeight="Bold" Foreground="#A6E3A1"/>
        </TextBlock>
        <Slider x:Name="ZoomLevelSlider" Minimum="1.5" Maximum="4.0"
                TickFrequency="0.1" IsSnapToTickEnabled="True"
                Value="2.0" ValueChanged="ZoomLevelSlider_ValueChanged"/>

        <TextBlock>
            <Run Text="Zoom Speed: "/>
            <Run x:Name="ZoomSpeedLabel" Text="300ms" FontWeight="Bold" Foreground="#A6E3A1"/>
        </TextBlock>
        <Slider x:Name="ZoomSpeedSlider" Minimum="100" Maximum="800"
                TickFrequency="50" IsSnapToTickEnabled="True"
                Value="300" ValueChanged="ZoomSpeedSlider_ValueChanged"/>

        <TextBlock>
            <Run Text="Cursor Tracking: "/>
            <Run x:Name="TrackingLabel" Text="Medium" FontWeight="Bold" Foreground="#A6E3A1"/>
        </TextBlock>
        <Slider x:Name="TrackingSlider" Minimum="0.05" Maximum="0.5"
                TickFrequency="0.05" IsSnapToTickEnabled="True"
                Value="0.25" ValueChanged="TrackingSlider_ValueChanged"/>

        <TextBlock>
            <Run Text="Cursor Ring Size: "/>
            <Run x:Name="RingSizeLabel" Text="40px" FontWeight="Bold" Foreground="#A6E3A1"/>
        </TextBlock>
        <Slider x:Name="RingSizeSlider" Minimum="20" Maximum="120"
                TickFrequency="5" IsSnapToTickEnabled="True"
                Value="80" ValueChanged="RingSizeSlider_ValueChanged"/>

        <TextBlock Text="Ring Color:" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton x:Name="ColorBlue" Content="Blue" Foreground="#CDD6F4"
                         GroupName="RingColor" IsChecked="True" Margin="0,0,12,0"/>
            <RadioButton x:Name="ColorYellow" Content="Yellow" Foreground="#CDD6F4"
                         GroupName="RingColor" Margin="0,0,12,0"/>
            <RadioButton x:Name="ColorRed" Content="Red" Foreground="#CDD6F4"
                         GroupName="RingColor" Margin="0,0,12,0"/>
            <RadioButton x:Name="ColorGreen" Content="Green" Foreground="#CDD6F4"
                         GroupName="RingColor" Margin="0,0,12,0"/>
            <RadioButton x:Name="ColorWhite" Content="White" Foreground="#CDD6F4"
                         GroupName="RingColor"/>
        </StackPanel>

        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows"
                  Foreground="#CDD6F4" Margin="0,4,0,20" IsChecked="True"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save &amp; Close" Width="110" Height="32"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="SemiBold"
                    BorderThickness="0" Click="SaveAndClose_Click" Cursor="Hand"/>
            <Button Content="Cancel" Width="80" Height="32" Margin="8,0,0,0"
                    Background="#45475A" Foreground="#CDD6F4"
                    BorderThickness="0" Click="Cancel_Click" Cursor="Hand"/>
        </StackPanel>
    </StackPanel>
</Window>

<Window x:Class="SmoothAnnotate.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmoothAnnotate"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Grid>
        <!-- Ink drawing layer (Pen, Highlighter, Eraser, Laser) -->
        <InkCanvas x:Name="DrawCanvas"
                   Background="Transparent"
                   EditingMode="None"
                   UseCustomCursor="False">
            <InkCanvas.DefaultDrawingAttributes>
                <DrawingAttributes Color="Red" Width="3" Height="3"
                                   FitToCurve="True" StylusTip="Ellipse"
                                   IgnorePressure="False"/>
            </InkCanvas.DefaultDrawingAttributes>
        </InkCanvas>

        <!-- Shape drawing layer (Arrow, Rectangle, Circle, Text) -->
        <Canvas x:Name="ShapeCanvas"
                Background="Transparent"
                IsHitTestVisible="False"/>

        <!-- Stopwatch HUD -->
        <Border x:Name="TimerContainer"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="20"
                Padding="12,6"
                CornerRadius="8"
                Background="#88000000"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <TextBlock x:Name="TimerText"
                       Text="00:00.0"
                       FontSize="28"
                       FontFamily="Consolas"
                       FontWeight="Bold"
                       Foreground="White">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8"
                                      ShadowDepth="2" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
        </Border>

        <!-- Confetti layer (on top of everything) -->
        <Canvas x:Name="ConfettiCanvas"
                Background="Transparent"
                IsHitTestVisible="False"/>
    </Grid>
</Window>

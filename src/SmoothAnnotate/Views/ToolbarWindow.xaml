<Window x:Class="SmoothAnnotate.Views.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmoothAnnotate Toolbar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <Border x:Name="MainBorder" CornerRadius="14"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F0141420" Offset="0"/>
                <GradientStop Color="#F01A1A2E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel Margin="8,10,8,8">
            <!-- Header with close button -->
            <Grid Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#FF4060" Margin="0,0,4,0"/>
                    <TextBlock Text="ANNOTATE"
                               FontSize="10"
                               FontFamily="Segoe UI"
                               FontWeight="Bold"
                               Foreground="#60FFFFFF"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="18" Height="18" CornerRadius="9"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonDown="CloseButton_Click"
                        Margin="0,-2,-2,0">
                    <TextBlock Text="✕" FontSize="10" Foreground="#60FFFFFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Drawing Tools Section -->
            <TextBlock Text="DRAW" FontSize="8" Foreground="#40FFFFFF"
                       FontFamily="Segoe UI" FontWeight="Bold" Margin="10,0,0,3"/>

            <Button x:Name="BtnPen" Tag="Pen" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Border Width="14" Height="14" CornerRadius="7" Margin="0,0,8,0">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFF4444" Offset="0.3"/>
                                <GradientStop Color="#80FF0000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Pen" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnHighlighter" Tag="Highlighter" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0"
                            Background="#64FFFF00"/>
                    <TextBlock Text="Highlight" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnLaser" Tag="Laser" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Border Width="14" Height="14" CornerRadius="7" Margin="0,0,8,0">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFF0000" Offset="0"/>
                                <GradientStop Color="#40FF0000" Offset="0.6"/>
                                <GradientStop Color="#00FF0000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Laser" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnEraser" Tag="Eraser" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,8,0"
                            Background="#40FFFFFF" BorderBrush="#60FFFFFF" BorderThickness="1"/>
                    <TextBlock Text="Eraser" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Shapes Section -->
            <Border Height="1" Background="#15FFFFFF" Margin="6,6"/>
            <TextBlock Text="SHAPES" FontSize="8" Foreground="#40FFFFFF"
                       FontFamily="Segoe UI" FontWeight="Bold" Margin="10,0,0,3"/>

            <Button x:Name="BtnArrow" Tag="Arrow" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="→" FontSize="14" Foreground="#80FFFFFF" Width="14"
                               TextAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Arrow" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnRect" Tag="Rectangle" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Border Width="14" Height="11" Margin="0,0,8,0"
                            BorderBrush="#80FFFFFF" BorderThickness="1.5" CornerRadius="2"/>
                    <TextBlock Text="Rect" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnCircle" Tag="Circle" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="13" Height="13" Margin="0,0,8,0"
                             Stroke="#80FFFFFF" StrokeThickness="1.5"/>
                    <TextBlock Text="Circle" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnText" Tag="Text" Click="ToolButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="A" FontSize="13" FontWeight="Bold" Foreground="#80FFFFFF"
                               Width="14" TextAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Text" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="BtnTextSize" Click="TextSizeButton_Click" Margin="2,0,2,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Aa" FontSize="10" Foreground="#60FFFFFF"
                               Width="14" TextAlignment="Center" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TextSizeLabel" Text="Medium" VerticalAlignment="Center"
                               FontSize="11" Foreground="#80FFFFFF"/>
                </StackPanel>
            </Button>

            <!-- Colors Section -->
            <Border Height="1" Background="#15FFFFFF" Margin="6,6"/>
            <TextBlock Text="COLOR" FontSize="8" Foreground="#40FFFFFF"
                       FontFamily="Segoe UI" FontWeight="Bold" Margin="10,0,0,3"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,4">
                <Border x:Name="Color1" Width="22" Height="22" CornerRadius="11"
                        Margin="3" Cursor="Hand" MouseLeftButtonDown="Color_Click" Tag="1"
                        BorderThickness="2" BorderBrush="Transparent">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFF4444" Offset="0.3"/>
                            <GradientStop Color="#CCFF0000" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
                <Border x:Name="Color2" Width="22" Height="22" CornerRadius="11"
                        Margin="3" Cursor="Hand" MouseLeftButtonDown="Color_Click" Tag="2"
                        BorderThickness="2" BorderBrush="Transparent">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF5090FF" Offset="0.3"/>
                            <GradientStop Color="#CC3278FF" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
                <Border x:Name="Color3" Width="22" Height="22" CornerRadius="11"
                        Margin="3" Cursor="Hand" MouseLeftButtonDown="Color_Click" Tag="3"
                        BorderThickness="2" BorderBrush="Transparent">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF30E870" Offset="0.3"/>
                            <GradientStop Color="#CC00C850" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
                <Border x:Name="Color4" Width="22" Height="22" CornerRadius="11"
                        Margin="3" Cursor="Hand" MouseLeftButtonDown="Color_Click" Tag="4"
                        BorderThickness="2" BorderBrush="Transparent"
                        Background="#EEFFFFFF"/>
                <Border x:Name="Color5" Width="22" Height="22" CornerRadius="11"
                        Margin="3" Cursor="Hand" MouseLeftButtonDown="Color_Click" Tag="5"
                        BorderThickness="2" BorderBrush="Transparent">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFF040" Offset="0.3"/>
                            <GradientStop Color="#CCFFE600" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>
            </StackPanel>

            <!-- Actions -->
            <Border Height="1" Background="#15FFFFFF" Margin="6,4"/>

            <Button x:Name="BtnClear" Click="ClearButton_Click" Margin="2,2">
                <TextBlock Text="Clear All" HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="BtnClickThrough" Click="ClickThroughButton_Click"
                    Margin="2,1" Visibility="Collapsed">
                <TextBlock Text="✕  Exit Draw" HorizontalAlignment="Center"/>
            </Button>
        </StackPanel>
    </Border>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BBFFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#35FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
